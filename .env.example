# Database
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/maazan
DATABASE_URL_SYNC=postgresql://postgres:your_password@localhost:5432/maazan

# Redis (optional for development - uses in-memory fallback if not set)
REDIS_URL=

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# OAuth (optional for development)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# App
APP_NAME=מאזן
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Cors
CORS_ORIGINS=["http://localhost:3000"]
